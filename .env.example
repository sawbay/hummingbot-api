# Hummingbot API Configuration
USERNAME=admin
PASSWORD=admin
CONFIG_PASSWORD=admin
DEBUG_MODE=false

# MQTT Broker
# BROKER_HOST=localhost
# BROKER_PORT=1883
# BROKER_USERNAME=
# BROKER_PASSWORD=
# BROKER_SSL=false

# Database (auto-configured by docker-compose)
DATABASE_URL=postgresql+asyncpg://hbot:hummingbot-api@localhost:5432/hummingbot_api

# Gateway (optional)
GATEWAY_URL=http://localhost:15888
GATEWAY_PASSPHRASE=admin

# Paths
BOTS_PATH=/home/steven/codekeeper/sawbay/hummingbot-api

# Cloudflare R2 durable bots file sync (optional)
R2_ENABLED=false
R2_BUCKET=
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PREFIX=bots
R2_SYNC_ON_STARTUP=true
